# Server Configuration
PORT=4000
NODE_ENV=production
FRONTEND_URL=https://whatsapp-bulk-ui.vercel.app

# WhatsApp Configuration
WHATSAPP_SESSION_PATH=/var/lib/whatsapp/session.db

# File Upload Configuration
UPLOAD_DIR=/var/lib/whatsapp/uploads
MAX_FILE_SIZE=10485760

# Rate Limiting
RATE_LIMIT_MIN_DELAY=3000
RATE_LIMIT_MAX_DELAY=5000

# IMPORTANT: Update FRONTEND_URL with your actual domain
# Example: https://whatsapp.yourdomain.com
